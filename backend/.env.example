# CRM Business Predictor - Environment Configuration
# Copy this file to .env and configure as needed

# Server Configuration
HOST=0.0.0.0
PORT=8000

# GPU Configuration (for RTX 4090)
USE_LOCAL_GPU=true
CUDA_VISIBLE_DEVICES=0

# Offline Mode Configuration
# Set to true to ensure no external API calls (except during model download)
OFFLINE_MODE=true

# Model Configuration
MODEL_TYPE=transformer  # Options: transformer, basic
MODELS_DIR=models

# OpenAI Configuration (Optional - only used if OFFLINE_MODE=false)
# Leave empty for offline operation
OPENAI_API_KEY=
USE_OPENAI=false

# HuggingFace Configuration
# These settings enable offline operation after models are downloaded
HF_DATASETS_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# Logging
LOG_LEVEL=INFO
